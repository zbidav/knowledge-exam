  <pair left="ריבוז (Ribose)"     right="פנטוז — חד-סוכר בן 5 פחמנים (מרכיב ב-RNA)" img=""/>
  <pair left="סוכרוז (Sucrose)"   right="דו-סוכר: גלוקוז + פרוקטוז" img=""/>
  <pair left="לקטוז (Lactose)"    right="דו-סוכר: גלוקוז + גלקטוז" img=""/>
  <pair left="גליקוגן (Glycogen)" right="רב-סוכר — מאגר גלוקוז מסועף בבעלי חיים" img=""/>
</matchset>
